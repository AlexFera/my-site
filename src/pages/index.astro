---
import BaseLayout from "../layouts/BaseLayout.astro";

const profileLinks = [
  { label: "LinkedIn", href: "https://www.linkedin.com/in/alexandru-fera/", icon: "linkedin" },
  { label: "GitHub", href: "https://github.com/AlexFera", icon: "github" },
  { label: "Resume", href: "/assets/resume-alexandru-fera.pdf", icon: "file" },
  { label: "Email", href: "mailto:alexandrufera@gmail.com", icon: "mail" },
];

const icons = {
  linkedin:
    '<svg aria-hidden="true" viewBox="0 0 24 24"><path fill="currentColor" d="M20.45 20.45h-3.56v-5.58c0-1.33-.02-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.95v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.32 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12Zm1.78 13.02H3.54V9H7.1v11.45Z"/></svg>',
  github:
    '<svg aria-hidden="true" viewBox="0 0 24 24"><path fill="currentColor" d="M12 .5a12 12 0 0 0-3.8 23.38c.6.11.82-.26.82-.58v-2.04c-3.34.73-4.04-1.6-4.04-1.6-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.8 1.3 3.49 1 .1-.78.42-1.31.76-1.61-2.67-.3-5.47-1.34-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.88.12 3.18a4.65 4.65 0 0 1 1.24 3.22c0 4.6-2.8 5.62-5.48 5.92.43.37.82 1.1.82 2.23v3.31c0 .32.22.7.83.58A12 12 0 0 0 12 .5Z"/></svg>',
  file:
    '<svg aria-hidden="true" viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" d="M14 3.5H7.2A2.2 2.2 0 0 0 5 5.7v12.6a2.2 2.2 0 0 0 2.2 2.2h9.6a2.2 2.2 0 0 0 2.2-2.2V8.5L14 3.5Z"/><path fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" d="M14 3.5v5h5M8.5 13h7M8.5 16h5"/></svg>',
  mail:
    '<svg aria-hidden="true" viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" d="M4.8 6.5h14.4c.72 0 1.3.58 1.3 1.3v8.4c0 .72-.58 1.3-1.3 1.3H4.8c-.72 0-1.3-.58-1.3-1.3V7.8c0-.72.58-1.3 1.3-1.3Z"/><path fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" d="m4 7.5 8 5.8 8-5.8"/></svg>',
};

const workAreas = [
  {
    code: "01",
    title: "Document-processing platforms",
    text: "Presentation import, OOXML/PPTX processing, headless browser runtimes and back-end coordination for product workflows at scale.",
  },
  {
    code: "02",
    title: "Distributed back-end systems",
    text: "Microservices, asynchronous processing, message-driven workflows, explicit state transitions, retries, duplicate detection and idempotency.",
  },
  {
    code: "03",
    title: "Delivery and platform engineering",
    text: "Docker, Kubernetes, Helm-style configuration, Azure DevOps, CI/CD, GitVersion, SonarQube and practical release workflows.",
  },
  {
    code: "04",
    title: "Diagnostics and engineering tooling",
    text: "OpenTelemetry-style diagnostics, logs, traces, correlation IDs, health checks, Playwright, CDP and memory-leak investigation workflows.",
  },
];

const selectedWork = [
  {
    title: "Adobe Express presentation import",
    text: "Back-end and platform engineering for presentation-import and document-processing workflows in Adobe Express, a large-scale product used by millions of customers.",
    details: [
      "TypeScript, Node.js and Bazel-based monorepo",
      "Microsoft PowerPoint / PPTX import, OOXML processing and service coordination",
      "Kubernetes-based infrastructure, internal platform abstractions and CI/CD",
      "Puppeteer, headless Chrome, Playwright and Chrome DevTools Protocol",
    ],
  },
  {
    title: "Confidential distributed ingestion platform",
    text: "Distributed .NET microservices for asynchronous file and report ingestion in a restricted enterprise environment, with metadata persistence, message broker coordination and Kubernetes deployment.",
    details: [
      ".NET, C#, SQL Server, background services and worker services",
      "Artemis / AMQP messaging and downstream integrations",
      "Idempotency, retries, duplicate detection, traceability and state transitions",
      "Kubernetes, Helm, Azure DevOps and operational diagnostics",
    ],
  },
  {
    title: "Memory-leak investigation tooling",
    text: "Developer-facing tooling around Playwright, Chrome DevTools Protocol and Memlab to make memory-leak investigation more repeatable and inspectable.",
    details: [
      "Automated heap snapshot collection through Playwright and CDP",
      "PostgreSQL persistence for memory-analysis results",
      "Vue dashboards for leaks and retainer chains",
    ],
  },
  {
    title: "Web platforms and document management",
    text: "ASP.NET Core and Vue applications, SPA migrations, document-management systems and reusable API support for filtering, sorting and pagination.",
    details: [
      "Vue 2/Webpack to Vue 3, TypeScript and Vite migrations",
      "Azure Blob Storage, PostgreSQL and Entity Framework Core",
      "Dynamic LINQ, Playwright E2E tests and maintainable app structure",
    ],
  },
];

const experienceTimeline = [
  {
    role: "Senior Software Engineer",
    company: "Adobe",
    period: "June 2024 - Present",
    text: "TypeScript, Node.js, Bazel, Adobe Express presentation import, PPTX/OOXML processing, headless Chrome automation, Kubernetes-based platform work and memory-leak investigation tooling.",
  },
  {
    role: "Senior .NET Developer",
    company: "RealPage",
    period: "June 2023 - June 2024",
    text: "Kafka-based streaming, Kubernetes deployment on Amazon EKS, Azure DevOps release pipelines, Testcontainers integration tests and static code analysis.",
  },
  {
    role: "Senior .NET Developer",
    company: "STIONA Software",
    period: "May 2019 - June 2023",
    text: "ASP.NET Core and Vue web platforms, document-management systems, Vue 3/TypeScript migrations, Dynamic LINQ APIs and Playwright E2E testing.",
  },
  {
    role: "Senior .NET Developer",
    company: "Equiniti",
    period: "November 2017 - May 2019",
    text: "Finance platform work with ASP.NET MVC, Kendo UI, WCF, SQL Server, SpecFlow, Selenium, NServiceBus and ASP.NET Core APIs.",
  },
  {
    role: "Team Lead / .NET Developer",
    company: "Eminus Software",
    period: "March 2013 - October 2017",
    text: "Multi-tenant ASP.NET systems, IdentityServer SSO, RabbitMQ integrations, Redis operations, TFS build workflows, WiX installers and technical design documentation.",
  },
];

const technologies = [
  "C#",
  ".NET",
  "ASP.NET Core",
  "TypeScript",
  "Node.js",
  "SQL Server",
  "PostgreSQL",
  "Vue",
  "Playwright",
  "Puppeteer",
  "Chrome DevTools Protocol",
  "Memlab",
  "OOXML / PPTX",
  "Kafka",
  "RabbitMQ",
  "Artemis / AMQP",
  "NServiceBus",
  "Docker",
  "Kubernetes",
  "Helm",
  "Azure DevOps",
  "Testcontainers",
  "OpenTelemetry",
  "IdentityServer",
];
---

<BaseLayout>
  <div class="site-shell">
  <header class="sticky top-0 z-20 border-b border-slate-200/80 bg-stone-50/90 backdrop-blur">
    <nav
      class="mx-auto flex max-w-6xl items-center justify-between gap-6 px-5 py-5 sm:px-8"
      aria-label="Primary navigation"
    >
      <a class="text-sm font-semibold tracking-[0.18em] text-slate-950 uppercase" href="#top">
        Alexandru Fera
      </a>
      <div class="hidden items-center gap-7 text-sm text-slate-600 sm:flex">
        <a class="link-underline hover:text-slate-950" href="#work">Work</a>
        <a class="link-underline hover:text-slate-950" href="#selected-work">Selected work</a>
        <a class="link-underline hover:text-slate-950" href="#experience">Experience</a>
        <a class="link-underline hover:text-slate-950" href="#stack">Stack</a>
        <a class="link-underline hover:text-slate-950" href="#contact">Contact</a>
      </div>
    </nav>
  </header>

  <main id="top">
    <section class="hero-surface relative overflow-hidden border-b border-slate-200/80">
      <div class="mx-auto grid max-w-6xl gap-12 px-5 py-14 sm:px-8 lg:grid-cols-[1.05fr_0.95fr] lg:py-16">
        <div class="max-w-3xl">
          <div class="mb-5 flex flex-wrap items-center gap-3 text-sm font-medium tracking-[0.16em] text-slate-500 uppercase">
            <span>Senior Software Engineer</span>
            <span class="hidden h-px w-10 bg-slate-300 sm:block"></span>
            <span>Senior .NET Developer</span>
          </div>
          <h1 class="text-4xl font-semibold leading-[1.07] tracking-normal text-slate-950 sm:text-5xl lg:text-5xl">
            Senior software engineer working on document-processing platforms and distributed back-end systems.
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-700">
            I build systems where reliability, traceability and operational visibility matter: Adobe Express presentation-import workflows, enterprise ingestion platforms, message-driven processing, CI/CD and engineering tooling.
          </p>
          <div class="mt-7 flex flex-wrap gap-3" aria-label="Profile links">
            {
              profileLinks.map((link) => (
                <a
                  class="profile-link inline-flex min-h-11 items-center gap-2 border border-slate-300 bg-white/65 px-4 text-sm font-medium text-slate-800 transition hover:border-slate-950 hover:bg-slate-950 hover:text-white"
                  href={link.href}
                  target={link.href.startsWith("http") ? "_blank" : undefined}
                  rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
                >
                  <span class="profile-link-icon" set:html={icons[link.icon]} />
                  {link.label}
                </a>
              ))
            }
          </div>
          <div class="mt-8 grid max-w-2xl grid-cols-2 gap-px overflow-hidden border border-slate-200 bg-slate-200 text-sm text-slate-700 sm:grid-cols-4">
            <span class="bg-white/70 px-3 py-2 font-medium">.NET</span>
            <span class="bg-white/70 px-3 py-2 font-medium">TypeScript</span>
            <span class="bg-white/70 px-3 py-2 font-medium">OOXML / PPTX</span>
            <span class="bg-white/70 px-3 py-2 font-medium">Kubernetes</span>
          </div>
        </div>

        <div class="grid gap-6 self-end">
          <figure class="portrait-panel justify-self-start lg:justify-self-end">
            <picture>
              <source srcset="/assets/images/portrait.webp" type="image/webp" />
              <img
                class="portrait-image"
                src="/assets/images/portrait.png"
                alt="Portrait of Alexandru Fera"
                width="1122"
                height="1402"
                loading="eager"
                decoding="async"
              />
            </picture>
          </figure>

          <aside class="max-w-xl border-l border-slate-300 pl-6 text-sm leading-7 text-slate-600 lg:justify-self-end">
            <p class="font-medium text-slate-950">Bucharest, Romania</p>
            <p class="mt-3">
              13+ years across product engineering, enterprise systems and independent consulting, mostly close to the boundary between application code, databases, message brokers, deployment pipelines and operations.
            </p>
            <p class="mt-5">
              I prefer explicit state, clear boundaries, useful tests, observable services and code that future teams can understand and operate.
            </p>
          </aside>
        </div>
      </div>
    </section>

    <section id="work" class="section-panel border-b border-slate-200/80 py-20">
      <div class="mx-auto max-w-6xl px-5 sm:px-8">
        <div class="max-w-2xl">
          <p class="text-sm font-medium tracking-[0.2em] text-slate-500 uppercase">What I work on</p>
          <h2 class="mt-4 text-3xl font-semibold tracking-normal text-slate-950 sm:text-4xl">
            Systems that need predictable behavior under real operational pressure.
          </h2>
        </div>

        <div class="mt-12 grid gap-px overflow-hidden border border-slate-200 bg-slate-200 md:grid-cols-2">
          {
            workAreas.map((area) => (
              <article class="work-card bg-stone-50 p-6 transition hover:bg-white sm:p-8">
                <span class="text-sm font-semibold tracking-[0.18em] text-blue-900/70">{area.code}</span>
                <h3 class="mt-5 text-xl font-semibold text-slate-950">{area.title}</h3>
                <p class="mt-4 text-base leading-7 text-slate-600">{area.text}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="selected-work" class="border-b border-slate-200/80 bg-white/55 py-20">
      <div class="mx-auto max-w-6xl px-5 sm:px-8">
        <div class="grid gap-10 lg:grid-cols-[0.7fr_1.3fr]">
          <div>
            <p class="text-sm font-medium tracking-[0.2em] text-slate-500 uppercase">Selected work</p>
            <h2 class="mt-4 text-3xl font-semibold tracking-normal text-slate-950 sm:text-4xl">
              Representative engineering work, with confidential details removed.
            </h2>
            <p class="mt-5 text-base leading-7 text-slate-700">
              The useful signal is the shape of the systems: document conversion, browser-backed runtimes, message-driven processing, deployment workflows and diagnostics.
            </p>
          </div>

          <div class="space-y-5">
            {
              selectedWork.map((item, index) => (
                <article class="case-note border border-slate-200 bg-white p-6 sm:p-7">
                  <div class="flex items-start gap-4">
                    <span class="case-index">{String(index + 1).padStart(2, "0")}</span>
                    <div>
                      <h3 class="text-xl font-semibold text-slate-950">{item.title}</h3>
                      <p class="mt-4 text-base leading-7 text-slate-700">{item.text}</p>
                    </div>
                  </div>
                  <ul class="mt-5 flex flex-wrap gap-2">
                    {item.details.map((detail) => (
                      <li class="border border-slate-200 bg-slate-50 px-3 py-1.5 text-sm text-slate-600">
                        {detail}
                      </li>
                    ))}
                  </ul>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section id="experience" class="border-b border-slate-200/80 py-20">
      <div class="mx-auto grid max-w-6xl gap-12 px-5 sm:px-8 lg:grid-cols-[0.9fr_1.1fr]">
        <div>
          <p class="text-sm font-medium tracking-[0.2em] text-slate-500 uppercase">Experience summary</p>
          <h2 class="mt-4 text-3xl font-semibold tracking-normal text-slate-950 sm:text-4xl">
            A senior engineering track through product, platform and enterprise systems.
          </h2>
        </div>

        <div>
          <ol class="space-y-6">
            {
              experienceTimeline.map((item) => (
                <li class="timeline-item border-l border-slate-300 pl-5">
                  <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
                    <h3 class="text-lg font-semibold text-slate-950">
                      {item.role} <span class="font-normal text-slate-500">/ {item.company}</span>
                    </h3>
                    <p class="text-sm font-medium text-slate-500">{item.period}</p>
                  </div>
                  <p class="mt-3 text-base leading-7 text-slate-700">{item.text}</p>
                </li>
              ))
            }
          </ol>
        </div>
      </div>
    </section>

    <section id="stack" class="section-panel border-b border-slate-200/80 py-20">
      <div class="mx-auto grid max-w-6xl gap-10 px-5 sm:px-8 lg:grid-cols-[0.8fr_1.2fr]">
        <div>
          <p class="text-sm font-medium tracking-[0.2em] text-slate-500 uppercase">Selected stack</p>
          <h2 class="mt-4 text-3xl font-semibold tracking-normal text-slate-950 sm:text-4xl">
            The tools change; the engineering habits stay steady.
          </h2>
          <p class="mt-5 text-base leading-7 text-slate-700">
            I use AI coding agents such as Claude Code and Codex CLI for exploration, refactoring and implementation support, while keeping design decisions, review and delivery under engineering control.
          </p>
        </div>

        <div class="self-start">
          <ul class="flex flex-wrap gap-2">
            {
              technologies.map((item) => (
                <li class="border border-slate-200 bg-white/75 px-3 py-1.5 text-sm font-medium text-slate-700">
                  {item}
                </li>
              ))
            }
            </ul>
        </div>
      </div>
    </section>

    <section id="contact" class="py-20">
      <div class="mx-auto max-w-6xl px-5 sm:px-8">
        <div class="max-w-3xl">
          <p class="text-sm font-medium tracking-[0.2em] text-slate-500 uppercase">Contact</p>
          <h2 class="mt-4 text-3xl font-semibold tracking-normal text-slate-950 sm:text-4xl">
            Professional contact starts with LinkedIn.
          </h2>
          <p class="mt-5 text-lg leading-8 text-slate-700">
            The best place to reach me professionally is LinkedIn. The resume has the fuller version of the work history, technologies and certifications.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a
              class="profile-link inline-flex min-h-11 items-center gap-2 bg-slate-950 px-4 text-sm font-medium text-white transition hover:bg-slate-700"
              href="https://www.linkedin.com/in/alexandru-fera/"
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="profile-link-icon" set:html={icons.linkedin} />
              LinkedIn
            </a>
            <a
              class="profile-link inline-flex min-h-11 items-center gap-2 border border-slate-300 bg-white/70 px-4 text-sm font-medium text-slate-800 transition hover:border-slate-950 hover:bg-white"
              href="mailto:contact@alexandrufera.com"
            >
              <span class="profile-link-icon" set:html={icons.mail} />
              Email
            </a>
            <a
              class="profile-link inline-flex min-h-11 items-center gap-2 border border-slate-300 bg-white/70 px-4 text-sm font-medium text-slate-800 transition hover:border-slate-950 hover:bg-white"
              href="/assets/resume-alexandru-fera.pdf"
            >
              <span class="profile-link-icon" set:html={icons.file} />
              Resume
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-slate-200/80 py-8">
    <div class="mx-auto flex max-w-6xl flex-col gap-3 px-5 text-sm text-slate-500 sm:flex-row sm:items-center sm:justify-between sm:px-8">
      <p>© {new Date().getFullYear()} Alexandru Fera</p>
      <p>Senior Software Engineer / Senior .NET Developer</p>
    </div>
  </footer>
  </div>
</BaseLayout>
